# ──────────────────────────────────────────────────────────────
# 凭证模板。复制为 .env 并填入真实值。.env 绝不进 git。
#
# 重要：第一阶段 C（自动分析 + 人工确认）完全不需要以下任何密钥，
#       因为只读市场数据、不发单，零资金风险。
#       下面的项仅在切换到阶段 A（全自动真实下单）时才需要填写。
# ──────────────────────────────────────────────────────────────

# 专用 Polygon 钱包私钥 —— 绝不能是你的主资产钱包！
# 单独新建一个钱包，只放小额，专供此机器人使用。
POLYGON_PRIVATE_KEY=

# Polymarket CLOB API 凭证（可由私钥派生或在 Polymarket 生成）
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=
